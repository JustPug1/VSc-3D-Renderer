{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build Drone Project",
            "command": "C:/mingw64/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/src/main.cpp",
                "${workspaceFolder}/src/pythonManager.cpp",
                "-o", "${workspaceFolder}/bin/DroneApp.exe",
                // Includes
                "-I${workspaceFolder}/include",
                "-IC:/SDL3-3.4.0/x86_64-w64-mingw32/include",
                "-IC:/Python/include",
                // Library Paths
                "-LC:/SDL3-3.4.0/x86_64-w64-mingw32/lib",
                "-LC:/Python/libs",
                // Libraries to link
                "-lSDL3",
                "-lpython310"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Compiles SDL3 and Python Embedded code together"
        }
    ]
}